{
  "name": "pihole-js",
  "version": "1.2.0",
  "description": "Framework-agnostic JavaScript API client for Pi-hole v6",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "test": "node --import tsx/esm --test tests/**/*.test.ts",
    "test:coverage": "node --import tsx/esm --experimental-test-coverage --test tests/**/*.test.ts",
    "release:patch": "pnpm version patch && git push && git push --tags",
    "release:minor": "pnpm version minor && git push && git push --tags",
    "release:major": "pnpm version major && git push && git push --tags"
  },
  "keywords": [
    "pihole",
    "pi-hole",
    "dns",
    "adblock",
    "api"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/creeperkatze/pihole-js"
  },
  "author": "Creeperkatze",
  "license": "AGPL-3.0-only",
  "packageManager": "pnpm@11.7.0+sha512.19cc852c120c7125760f2443ee6be0ca5b40f9f50598de1a09a1f177503e010e57c23c77646e01e761de59bf874fb22a3398c33ab9691fc13eb946b6f0f4d620",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
